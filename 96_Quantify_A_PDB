    "from typing import *\n",
    "import pandas as pd\n",
    "\n",
    "\n",
    "def SIFTS_mapping_between_pdb_uniprot(pdb_id: str) ->  Dict[str, Any]:\n",
    "    \"\"\"\n",
    "    Description\n",
    "    -----------\n",
    "    给定1个PDB id, 获取其每条chain的uniprot序列映射信息.\n",
    "    ⚠️ 注意本函数只能实现区间范围mapping, 如果要逐残基mapping需要parse_sifts等更深入的脚本\n",
    "    \n",
    "    Args\n",
    "    ----\n",
    "    pdb_id: str\n",
    "        PDB id, 4位字符.\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    mapping_info: Dict[str, Any]\n",
    "        包含每条chain的uniprot序列映射信息的字典.\n",
    "    \n",
    "    \"\"\"\n",
    "    import httpx\n",
    "    pdb_id = pdb_id.lower()\n",
    "    url = f\"https://www.ebi.ac.uk/pdbe/api/v2/mappings/uniprot/{pdb_id}\"\n",
    "    response = httpx.get(url)\n",
    "    data = response.json()\n",
    "    \n",
    "    # 存储每1个entity\n",
    "    rows = []\n",
    "\n",
    "    for entity_id, entity_info in data[pdb_id]['UniProt'].items():\n",
    "        # 每1个区间都是1个元组, 然后按照列表来存储\n",
    "        struct_ranges = list()\n",
    "        seq_ranges = list()\n",
    "        for mapping in entity_info['mappings']:\n",
    "            # 每1个mapping都是一个区间范围的mapping字典, 包含了pdb的chain id、start end等信息\n",
    "            struct_start = mapping['start']['residue_number']\n",
    "            struct_end = mapping['end']['residue_number']\n",
    "            seq_start = mapping['unp_start']\n",
    "            seq_end = mapping['unp_end']\n",
    "\n",
    "            # 如何将每一个区间都对应起来？\n",
    "            # 按照列表的形式来存储每一个区间的mapping关系, 到时候后就是zip(struct_ranges, seq_ranges)了, 注意一定要对应\n",
    "            struct_ranges.append((struct_start, struct_end))\n",
    "            seq_ranges.append((seq_start, seq_end))\n",
    "        \n",
    "        rows.append({\n",
    "            'entity_id': entity_id,\n",
    "            'PDB_ranges': struct_ranges,\n",
    "            'Uniprot_ranges': seq_ranges\n",
    "        })\n",
    "\n",
    "    df = pd.DataFrame(rows)\n",
    "    return df\n"
   ]
