    "def _explode_rows(\n",
    "            df: pd.DataFrame,\n",
    "            uid_col: str,\n",
    "            region_col: str,\n",
    "            source_col: str,\n",
    "        ) -> pd.DataFrame:\n",
    "            rows: List[Dict[str, str]] = []\n",
    "            for _, row in df.iterrows():\n",
    "                uid_cell = row.get(uid_col)\n",
    "                region_cell = row.get(region_col)\n",
    "                source_cell = row.get(source_col)\n",
    "\n",
    "                if pd.isna(uid_cell) or pd.isna(region_cell):\n",
    "                    continue\n",
    "\n",
    "                region_text = str(region_cell).strip()\n",
    "                if not region_text:\n",
    "                    continue\n",
    "\n",
    "                source_text = str(source_cell).strip() if pd.notna(source_cell) else \"\"\n",
    "                if not source_text:\n",
    "                    continue\n",
    "\n",
    "                uid_list = [u.strip() for u in str(uid_cell).split(\",\") if u and str(u).strip()]\n",
    "                for uid in uid_list:\n",
    "                    core_uid = uid.split(\"-\")[0].strip().upper()\n",
    "                    if not core_uid:\n",
    "                        continue\n",
    "                    rows.append(\n",
    "                        {\n",
    "                            \"query_uniprot_id\": core_uid,\n",
    "                            \"disorder_region\": region_text,\n",
    "                            \"source_annotation\": source_text,\n",
    "                        }\n",
    "                    )\n",
    "\n",
    "            return pd.DataFrame(rows)\n",
    "\n",
    "disprot_rows = _explode_rows(\n",
    "            df_disprot,\n",
    "            uid_col=\"Uniprot ID\",\n",
    "            region_col=\"Disorder regions\",\n",
    "            source_col=\"Disprot ID\",\n",
    "        )\n",
    "ideal_rows = _explode_rows(\n",
    "            df_ideal,\n",
    "            uid_col=\"Uniprot ID\",\n",
    "            region_col=\"Disorder regions\",\n",
    "            source_col=\"IDP ID\",\n",
    "        )\n",
    "mobidb_rows = _explode_rows(\n",
    "            df_mobidb,\n",
    "            uid_col=\"Uniprot ID\",\n",
    "            region_col=\"Uniprot boundary\",\n",
    "            source_col=\"Source_Annotation\",\n",
    "        )\n",
    "\n",
    "# 合并所有注释行, 现在是每1个uniprot id对应1行\n",
    "merged_rows = pd.concat([disprot_rows, ideal_rows, mobidb_rows], ignore_index=True)"
   ]
  },
