    "# ==========================================\n",
    "# 1. 构建节点表 (Node Table) - df_chain\n",
    "# 目标：一行代表一条链，特征全都平行数组化（化为List）\n",
    "# ==========================================\n",
    "\n",
    "# a. 统一 df 的列名，并提取我们需要的元数据字段\n",
    "# 结构文件的 chain_id 通常对应于 df 表中的 \"Auth Asym ID\"\n",
    "df_meta = df.rename(columns={'Auth Asym ID': 'chain_id'})[['Entity ID', 'chain_id', 'Uniprot ID', 'Sequence', 'IDR_region']]\n",
    "\n",
    "# b. 确保 df_sifts 的坐标是标准 numpy 数组格式，方便后续计算\n",
    "df_sifts['CA_coord'] = df_sifts['CA_coord'].apply(lambda x: np.array(x, dtype=float))\n",
    "\n",
    "# c. 聚合 df_sifts，生成节点表\n",
    "df_chain = df_sifts.groupby(['pdb_id', 'chain_id']).agg(\n",
    "    seq_idx=('residue_number', list),      # 原始结构映射到序列层面的 index (可能不连续)\n",
    "    residue_name=('residue_name', list),   # 氨基酸名称列表\n",
    "    ca_coord=('CA_coord', list)            # 坐标张量列表\n",
    ").reset_index()\n",
    "\n",
    "# d. 与 df_meta 合并，把 Uniprot ID 和 IDR_region 注释打上去\n",
    "df_chain = df_chain.merge(df_meta, on='chain_id', how='left')\n",
    "\n",
    "# e. 根据 IDR_region 计算布尔掩码数组 is_idr\n",
    "def get_idr_mask(seq_idx_list, idr_regions):\n",
    "    if not isinstance(idr_regions, list) or len(idr_regions) == 0:\n",
    "        return [False] * len(seq_idx_list)\n",
