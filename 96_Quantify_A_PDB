    "import numpy as np\n",
    "import pandas as pd\n",
    "import itertools\n",
    "\n",
    "# ==========================================\n",
    "# 1. 构建节点表 (Node Table) - df_chain\n",
    "# 目标：一行代表一条链，特征全都平行数组化（化为List）\n",
    "# ==========================================\n",
    "\n",
    "# a. 统一 df 的列名，并提取我们需要的元数据字段\n",
    "# 结构文件的 chain_id 通常对应于 df 表中的 \"Auth Asym ID\"\n",
    "df_meta = df.rename(columns={'Auth Asym ID': 'chain_id'})[['Entity ID', 'chain_id', 'Uniprot ID', 'Sequence', 'IDR_region']]\n",
    "\n",
    "# b. 确保 df_sifts 的坐标是标准 numpy 数组格式，方便后续计算\n",
    "df_sifts['CA_coord'] = df_sifts['CA_coord'].apply(lambda x: np.array(x, dtype=float))\n",
    "\n",
    "# c. 聚合 df_sifts，生成节点表\n",
    "df_chain = df_sifts.groupby(['pdb_id', 'chain_id']).agg(\n",
    "    seq_idx=('residue_number', list),      # 原始结构映射到序列层面的 index (可能不连续)\n",
    "    residue_name=('residue_name', list),   # 氨基酸名称列表\n",
    "    ca_coord=('CA_coord', list)            # 坐标张量列表\n",
    ").reset_index()\n",
    "\n",
    "# d. 与 df_meta 合并，把 Uniprot ID 和 IDR_region 注释打上去\n",
    "df_chain = df_chain.merge(df_meta, on='chain_id', how='left')\n",
    "\n",
    "# e. 根据 IDR_region 计算布尔掩码数组 is_idr\n",
    "def get_idr_mask(seq_idx_list, idr_regions):\n",
    "    if not isinstance(idr_regions, list) or len(idr_regions) == 0:\n",
    "        return [False] * len(seq_idx_list)\n",
    "    mask = []\n",
    "    for idx in seq_idx_list:\n",
    "        # 判断残基是否落在任何一个 IDR (start, end) 区间内\n",
    "        is_in_idr = any(start <= idx <= end for start, end in idr_regions)\n",
    "        mask.append(is_in_idr)\n",
    "    return mask\n",
    "   \n",
    "df_chain['is_idr'] = df_chain.apply(lambda row: get_idr_mask(row['seq_idx'], row['IDR_region']), axis=1)\n",
    "# 为图神经网络顺便生成 1 开始的连续序号作为图节点连续 id\n",
    "df_chain['model_idx'] = df_chain['seq_idx'].apply(lambda x: list(range(1, len(x) + 1)))\n",
    "\n",
    "\n",
    "# ==========================================\n",
    "# 2. 构建边接触表 (Edge Table) - df_contacts\n",
    "# 目标：挑选出两两距离 <= 8Å 的残基对，一行代表一个真实接触边\n",
    "# ==========================================\n",
    "contact_rows = [] \n",
    "distance_cutoff = 8.0        # 8Å 的距离阈值     \n",
    "\n",
    "# 按照 chain_id 进行分组，获取每个链的连续结构截面\n",
    "chain_groups = {c: g.reset_index(drop=True) for c, g in df_sifts.groupby('chain_id')}\n",
    "chains = sorted(chain_groups.keys())\n",
    "                \n",
    "# 在遍历 chain_i, chain_j 构建前，先准备一个快速查询 chain 到 IDR_region 的字典，提高效率\n",
    "chain_idr_dict = dict(zip(df_meta['chain_id'], df_meta['IDR_region']))\n",
    "                \n",
    "def check_in_idr(seq_idx, idr_regions):\n",
    "    if not isinstance(idr_regions, list) or len(idr_regions) == 0:\n",
    "        return False\n",
    "    return any(start <= seq_idx <= end for start, end in idr_regions)\n",
    "               \n",
    "                \n",
    "# 两两遍历所有的链（combinations_with_replacement 包含自己与自己的链内接触，及不同链间的接触）\n",
    "for chain_i, chain_j in itertools.combinations_with_replacement(chains, 2):\n",
    "    g_i = chain_groups[chain_i]   \n",
    "    g_j = chain_groups[chain_j]          \n",
    "                                                                                                                                            \n",
    "    # 提取 (N, 3) 形状的坐标矩阵    \n",
    "    coords_i = np.stack(g_i['CA_coord'].values)\n",
    "    coords_j = np.stack(g_j['CA_coord'].values)\n",
    "    \n",
    "    # 利用 numpy 广播机制进行批量的距离矩阵计算 (N, M)       \n",
    "    dist_matrix = np.linalg.norm(coords_i[:, None, :] - coords_j[None, :, :], axis=-1)\n",
    "    \n",
    "    # 总而言之, 下面的计算链间只计算了对称的一半（外层循环组合层面）, 链内也只计算了对称的一半（手动掩码层面）\n",
    "    # intra 链内      \n",
    "    # 链内因为同链距离矩阵是方阵, 所以需要掩码                                                                          \n",
    "    if chain_i == chain_j:       \n",
    "        # 链内接触：自己与自己的对角线接触(距为0)还是要保留，剔除重复的镜像边 (仅取左下或右上三角：idx_i < idx_j)\n",
    "        idx_i, idx_j = np.where(dist_matrix <= distance_cutoff) \n",
    "        # 下三角掩码，保证每对残基只计算一次\n",
    "        valid_mask = idx_i < idx_j    \n",
    "        idx_i, idx_j = idx_i[valid_mask], idx_j[valid_mask]    \n",
    "    # inter 链间\n",
    "    # 链间因为itertools.combinations_with_replacement循环不会生成对称chain pair, 所以不需要掩码\n",
    "    else:      \n",
    "        # 链间接触：直接抓取所有 <= cutoff \n",
    "        idx_i, idx_j = np.where(dist_matrix <= distance_cutoff)\n",
    "         \n",
    "    # 提取当前链的 IDR_region \n",
    "    idr_reg_i = chain_idr_dict.get(chain_i, [])\n",
    "    idr_reg_j = chain_idr_dict.get(chain_j, [])\n",
    "\n",
    "    # 将找到的有效边索引解包入库\n",
    "    for i, j in zip(idx_i, idx_j):\n",
    "        seq_i = g_i.iloc[i]['residue_number']\n",
    "        seq_j = g_j.iloc[j]['residue_number']\n",
    "        \n",
    "        contact_rows.append({\n",
    "            'pdb_id': g_i.iloc[i]['pdb_id'],\n",
    "            'chain_i': chain_i,\n",
    "            'chain_j': chain_j,\n",
    "            # 1. 增加结构层面的连续图索引 (为了后续构建 GNN Edge Index)\n",
    "            'model_idx_i': i + 1,           \n",
    "            'model_idx_j': j + 1,     \n",
    "            # 2. 保留原有序列生物学映射索引\n",
    "            'seq_idx_i': seq_i, \n",
    "            'seq_idx_j': seq_j, \n",
    "            # 3. 增加边节点的 IDR 掩码信息\n",
    "            'is_idr_i': check_in_idr(seq_i, idr_reg_i),\n",
    "            'is_idr_j': check_in_idr(seq_j, idr_reg_j),\n",
    "            'distance': dist_matrix[i, j]\n",
    "        })\n",
    "\n",
    "df_contacts = pd.DataFrame(contact_rows)  "
   ]
  },
